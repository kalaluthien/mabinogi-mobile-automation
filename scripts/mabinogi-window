#!/usr/bin/env bash
#
# mabinogi-window — position the 마비노기 모바일 (Mabinogi Mobile) window between the
# main monitor ("foreground") and the BetterDisplay virtual monitor ("background").
#
# Usage:
#   mabinogi-window status       # report which monitor the window is on
#   mabinogi-window foreground   # move to the main monitor and focus it
#   mabinogi-window background   # park it on the virtual monitor (no focus)
#   mabinogi-window toggle       # flip to the other monitor based on current location
#   mabinogi-window screenshot   # capture the monitor the window is on, open in Preview (no move)
#
# The moves are idempotent: foreground/background do nothing (beyond re-focusing
# for foreground) when the window is already on the target monitor. screenshot
# never moves or focuses the window.
#
# Requires: Accessibility permission for the app that runs this (iTerm2 / Terminal).
#   System Settings > Privacy & Security > Accessibility > enable your terminal.
#
set -euo pipefail

APP_PROCESS_NAME="ProductName"        # iOS-on-Mac wrapper process name
APP_BUNDLE_ID="com.nexon.devcat.mm"   # for reference; Mabinogi Mobile

action="${1:-}"

# Print the header comment block (stops at the first non-comment line).
usage() { awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"; exit 1; }
die()   { echo "ERROR: $*" >&2; exit 1; }

# Turn an osascript failure into a friendly message and exit. Call at top level
# (not inside $(...)) so the exit propagates.
fail_osascript() {
  local out="$1"
  if grep -q "assistive access\|-1719" <<<"$out"; then
    echo "ERROR: Accessibility permission is not granted." >&2
    echo "  Grant it: System Settings > Privacy & Security > Accessibility > enable your terminal (iTerm2)." >&2
    echo "  Then re-run this command." >&2
  else
    echo "ERROR: $out" >&2
  fi
  exit 1
}

# --- Display queries (pure) ----------------------------------------------------

# Live display bounds (logical points) via CoreGraphics.
# Emits one line per display: "MAIN x y w h" or "SEC x y w h".
display_bounds() {
  swift - <<'SWIFT'
import CoreGraphics
var count: UInt32 = 0
CGGetOnlineDisplayList(16, nil, &count)
var ids = [CGDirectDisplayID](repeating: 0, count: Int(count))
CGGetOnlineDisplayList(count, &ids, &count)
let main = CGMainDisplayID()
for id in ids {
  let b = CGDisplayBounds(id)
  let tag = (id == main) ? "MAIN" : "SEC"
  print("\(tag) \(Int(b.origin.x)) \(Int(b.origin.y)) \(Int(b.size.width)) \(Int(b.size.height))")
}
SWIFT
}

# Target display rectangle: "main" -> main monitor, "virtual" -> first secondary.
pick_display() {
  local which="$1"
  if [[ "$which" == "main" ]]; then
    awk '$1=="MAIN"{print $2,$3,$4,$5; exit}' <<<"$(display_bounds)"
  else
    awk '$1=="SEC"{print $2,$3,$4,$5; exit}' <<<"$(display_bounds)"
  fi
}

# Map a window centre-x to a location name: "foreground" | "background" | "offscreen".
locate_center() {
  local cx="$1" tag x y w h loc="offscreen"
  while read -r tag x y w h; do
    if (( cx >= x && cx < x + w )); then
      [[ "$tag" == "MAIN" ]] && loc="foreground" || loc="background"
    fi
  done < <(display_bounds)
  echo "$loc"
}

# --- Window state (System Events) ---------------------------------------------

# Read the window frame into globals FRAME_{PX,PY,W,H}. Exits on failure.
FRAME_PX= FRAME_PY= FRAME_W= FRAME_H=
load_window_frame() {
  local out rc
  set +e
  out="$(osascript - "$APP_PROCESS_NAME" <<'APPLESCRIPT' 2>&1
on run argv
  set procName to item 1 of argv
  tell application "System Events"
    if not (exists process procName) then error "Mabinogi is not running (process " & procName & " not found)."
    set p to first process whose name is procName
    set w to first window of p
    set {px, py} to position of w
    set {ww, wh} to size of w
    return (px as text) & " " & (py as text) & " " & (ww as text) & " " & (wh as text)
  end tell
end run
APPLESCRIPT
)"
  rc=$?
  set -e
  [[ $rc -ne 0 ]] && fail_osascript "$out"
  read -r FRAME_PX FRAME_PY FRAME_W FRAME_H <<<"$out"
}

# Where does the window currently sit? Requires load_window_frame first.
window_location() { locate_center $((FRAME_PX + FRAME_W / 2)); }

# --- Commands ------------------------------------------------------------------

# Move (and optionally focus) the window, centred on the given display rect.
move_window() {
  local dx="$1" dy="$2" dw="$3" dh="$4" focus="$5" out rc
  set +e
  out="$(osascript - "$APP_PROCESS_NAME" "$dx" "$dy" "$dw" "$dh" "$focus" <<'APPLESCRIPT' 2>&1
on run argv
  set procName to item 1 of argv
  set dx to (item 2 of argv) as integer
  set dy to (item 3 of argv) as integer
  set dw to (item 4 of argv) as integer
  set dh to (item 5 of argv) as integer
  set focusIt to (item 6 of argv) is "focus"
  tell application "System Events"
    if not (exists process procName) then error "Mabinogi is not running (process " & procName & " not found)."
    set p to first process whose name is procName
    set w to first window of p
    set {ww, wh} to size of w
    set nx to dx + ((dw - ww) div 2)
    set ny to dy + ((dh - wh) div 2)
    if ny < dy then set ny to dy
    set position of w to {nx, ny}
    if focusIt then set frontmost of p to true
    return "moved to " & nx & "," & ny & " (window " & ww & "x" & wh & ")"
  end tell
end run
APPLESCRIPT
)"
  rc=$?
  set -e
  [[ $rc -ne 0 ]] && fail_osascript "$out"
  echo "$out"
}

# Raise the app without moving its window (idempotent: frontmost=true twice is
# the same as once).
focus_window() {
  local out rc
  set +e
  out="$(osascript - "$APP_PROCESS_NAME" <<'APPLESCRIPT' 2>&1
on run argv
  set procName to item 1 of argv
  tell application "System Events"
    if not (exists process procName) then error "Mabinogi is not running (process " & procName & " not found)."
    set frontmost of (first process whose name is procName) to true
  end tell
end run
APPLESCRIPT
)"
  rc=$?
  set -e
  [[ $rc -ne 0 ]] && fail_osascript "$out"
}

# Move the window to a named location: "foreground" (main, focused) or
# "background" (virtual, unfocused). Idempotent: if the window is already on the
# target monitor, do not move it — only re-assert focus for foreground.
move_to() {
  local target="$1" x y w h
  load_window_frame
  if [[ "$(window_location)" == "$target" ]]; then
    if [[ "$target" == "foreground" ]]; then
      focus_window
      echo "already on main monitor (foreground) at (${FRAME_PX},${FRAME_PY}); focused, no move"
    else
      echo "already on virtual monitor (background) at (${FRAME_PX},${FRAME_PY}); no move"
    fi
    return
  fi
  if [[ "$target" == "foreground" ]]; then
    read -r x y w h <<<"$(pick_display main)"
    move_window "$x" "$y" "$w" "$h" focus
  else
    read -r x y w h <<<"$(pick_display virtual)"
    [[ -z "${x:-}" ]] && die "no virtual/secondary monitor found. Is the BetterDisplay virtual screen enabled?"
    move_window "$x" "$y" "$w" "$h" nofocus
  fi
}

# Report which monitor the window currently sits on.
do_status() {
  load_window_frame
  local loc label
  loc="$(window_location)"
  case "$loc" in
    foreground) label="main monitor (foreground)" ;;
    background) label="virtual monitor (background)" ;;
    *)          label="off-screen / unknown" ;;
  esac
  echo "Mabinogi window at (${FRAME_PX},${FRAME_PY}) size ${FRAME_W}x${FRAME_H} -> ${label}"
}

# Capture the monitor the window currently sits on and open it in Preview.
# Read-only: never moves or focuses the window. Uses region capture (-R) keyed to
# the live display bounds, so it works for the off-screen virtual monitor too.
do_screenshot() {
  load_window_frame
  local loc x y w h
  loc="$(window_location)"
  case "$loc" in
    foreground) read -r x y w h <<<"$(pick_display main)" ;;
    background) read -r x y w h <<<"$(pick_display virtual)" ;;
    *)          die "window is off-screen/unknown; move it to a monitor first." ;;
  esac
  local shot_dir out
  shot_dir="${TMPDIR:-/tmp}/mabinogi-window"
  mkdir -p "$shot_dir"
  out="${shot_dir}/${loc}.png"                       # fixed path per location: overwritten, never accumulates
  screencapture -x -R"${x},${y},${w},${h}" "$out" || die "screencapture failed."
  open "$out"
  echo "captured ${loc} monitor (${x},${y} ${w}x${h}) -> ${out} (opened in Preview)"
}

# Flip the window to the other monitor based on where it is now.
do_toggle() {
  load_window_frame
  local loc
  loc="$(window_location)"
  case "$loc" in
    foreground) move_to background ;;
    background) move_to foreground ;;
    *)          echo "Window is off-screen/unknown; bringing it to the foreground." >&2
                move_to foreground ;;
  esac
}

case "$action" in
  status|st)        do_status ;;
  foreground|fg)    move_to foreground ;;
  background|bg)    move_to background ;;
  toggle|tg)        do_toggle ;;
  screenshot|shot|ss) do_screenshot ;;
  *)                usage ;;
esac
