#!/usr/bin/env bash
#
# check-completion-sync — fail if the committed zsh completion has drifted from
# the script's subcommand table. scripts/mabinogi-window is the single source of
# truth; completions/_mabinogi-window is generated from it (`__complete`).
#
# Run by the pre-commit framework (see .pre-commit-config.yaml), or by hand.
#
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

script="scripts/mabinogi-window"
completion="completions/_mabinogi-window"

if ! diff -u "$completion" <("./$script" __complete); then
  echo "ERROR: $completion is out of sync with $script." >&2
  echo "  Regenerate and stage it:" >&2
  echo "    ./$script __complete >| $completion && git add $completion" >&2
  exit 1
fi
