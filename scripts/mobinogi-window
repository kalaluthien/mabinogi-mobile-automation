#!/usr/bin/env bash
#
# mobinogi-window — position the 마비노기 모바일 (Mabinogi Mobile) window between the
# main monitor ("foreground") and the BetterDisplay virtual monitor ("background").
#
# Two kinds of command: read the state, or set it to a desired state.
#   Read:
#     mobinogi-window status       # report on/off, and if on, which monitor
#     mobinogi-window screenshot   # capture just the game window, open in Preview
#   Set desired state (idempotent):
#     mobinogi-window on           # ensure the app is running (launch to main if not)
#     mobinogi-window off          # quit the app
#     mobinogi-window foreground   # move to the main monitor and focus it
#     mobinogi-window background   # park it on the virtual monitor (no focus)
#
# on/off are the app's power switch, foreground/background move a running window.
# on launches the app onto the main monitor only when it is NOT already running;
# if it is already running, on leaves the window where it is (no move, no focus).
# off quits the app. Both are idempotent: on is a no-op when already running, off
# a no-op when already stopped. Because "off" is a real state, a stopped app is
# NOT an error — status reports it as "off" and exits 0.
#
# The moves are idempotent: foreground/background do nothing (beyond re-focusing
# for foreground) when the window is already on the target monitor. screenshot
# captures only the app window (by window id) — no desktop — and never moves or
# focuses it, so it works even while the window is parked off-screen.
#
# Requires: Accessibility permission for the app that runs this (iTerm2 / Terminal).
#   System Settings > Privacy & Security > Accessibility > enable your terminal.
#
set -euo pipefail

# Identify the app by BUNDLE ID, not process name. The wrapper process is named
# "ProductName" — the default Xcode $(PRODUCT_NAME) placeholder Nexon shipped
# unset — which is both unstable across updates and prone to collide with any
# other sloppily-built iOS-on-Mac app. The bundle id is the stable, unique key.
APP_BUNDLE_ID="com.nexon.devcat.mm"   # Mabinogi Mobile; the match key everywhere
APP_LABEL="Mabinogi Mobile"           # human label for messages only

action="${1:-}"

# Print the header comment block (stops at the first non-comment line).
usage() { awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"; exit 1; }
die()   { echo "ERROR: $*" >&2; exit 1; }

# Turn an osascript failure into a friendly message and exit. Call at top level
# (not inside $(...)) so the exit propagates.
fail_osascript() {
  local out="$1"
  if grep -q "assistive access\|-1719" <<<"$out"; then
    echo "ERROR: Accessibility permission is not granted." >&2
    echo "  Grant it: System Settings > Privacy & Security > Accessibility > enable your terminal (iTerm2)." >&2
    echo "  Then re-run this command." >&2
  else
    echo "ERROR: $out" >&2
  fi
  exit 1
}

# --- Display queries (pure) ----------------------------------------------------

# Live display bounds (logical points) via CoreGraphics.
# Emits one line per display: "MAIN x y w h" or "SEC x y w h".
display_bounds() {
  swift - <<'SWIFT'
import CoreGraphics
var count: UInt32 = 0
CGGetOnlineDisplayList(16, nil, &count)
var ids = [CGDirectDisplayID](repeating: 0, count: Int(count))
CGGetOnlineDisplayList(count, &ids, &count)
let main = CGMainDisplayID()
for id in ids {
  let b = CGDisplayBounds(id)
  let tag = (id == main) ? "MAIN" : "SEC"
  print("\(tag) \(Int(b.origin.x)) \(Int(b.origin.y)) \(Int(b.size.width)) \(Int(b.size.height))")
}
SWIFT
}

# Target display rectangle: "main" -> main monitor, "virtual" -> first secondary.
pick_display() {
  local which="$1"
  if [[ "$which" == "main" ]]; then
    awk '$1=="MAIN"{print $2,$3,$4,$5; exit}' <<<"$(display_bounds)"
  else
    awk '$1=="SEC"{print $2,$3,$4,$5; exit}' <<<"$(display_bounds)"
  fi
}

# Map a window centre-x to a location name: "foreground" | "background" | "offscreen".
locate_center() {
  local cx="$1" tag x y w h loc="offscreen"
  while read -r tag x y w h; do
    if (( cx >= x && cx < x + w )); then
      [[ "$tag" == "MAIN" ]] && loc="foreground" || loc="background"
    fi
  done < <(display_bounds)
  echo "$loc"
}

# --- App process (lifecycle) --------------------------------------------------

# PID of the running app, matched by bundle id via lsappinfo. Empty when the app
# is not running (its "off" state) — callers treat empty as off, never an error.
app_pid() {
  lsappinfo info -only pid "$APP_BUNDLE_ID" 2>/dev/null \
    | sed -n 's/.*"pid"=\([0-9][0-9]*\).*/\1/p'
}

# True while the running app owns at least one window. Used to wait out the gap
# between launch and the window appearing. Non-fatal: a missing process is just
# "no window yet", not an error.
has_window() {
  local out rc
  set +e
  out="$(osascript - "$APP_BUNDLE_ID" <<'APPLESCRIPT' 2>&1
on run argv
  set bundleID to item 1 of argv
  tell application "System Events"
    if not (exists (first process whose bundle identifier is bundleID)) then return "0"
    set p to first process whose bundle identifier is bundleID
    if (count of windows of p) is 0 then return "0"
    return "1"
  end tell
end run
APPLESCRIPT
)"
  rc=$?
  set -e
  [[ $rc -eq 0 && "$out" == "1" ]]
}

# Wait up to ~30s for a freshly launched app to put up its window. Returns 1 on
# timeout so the caller can report a clear failure instead of moving a ghost.
wait_for_window() {
  local i
  for i in $(seq 1 60); do
    has_window && return 0
    sleep 0.5
  done
  return 1
}

# --- Window state (System Events) ---------------------------------------------

# Read the window frame into globals FRAME_{PX,PY,W,H}. Exits on failure.
FRAME_PX= FRAME_PY= FRAME_W= FRAME_H=
load_window_frame() {
  local out rc
  set +e
  out="$(osascript - "$APP_BUNDLE_ID" <<'APPLESCRIPT' 2>&1
on run argv
  set bundleID to item 1 of argv
  tell application "System Events"
    if not (exists (first process whose bundle identifier is bundleID)) then error "Mabinogi Mobile is not running (bundle " & bundleID & " not found)."
    set p to first process whose bundle identifier is bundleID
    set w to first window of p
    set {px, py} to position of w
    set {ww, wh} to size of w
    return (px as text) & " " & (py as text) & " " & (ww as text) & " " & (wh as text)
  end tell
end run
APPLESCRIPT
)"
  rc=$?
  set -e
  [[ $rc -ne 0 ]] && fail_osascript "$out"
  read -r FRAME_PX FRAME_PY FRAME_W FRAME_H <<<"$out"
}

# Where does the window currently sit? Requires load_window_frame first.
window_location() { locate_center $((FRAME_PX + FRAME_W / 2)); }

# --- Commands ------------------------------------------------------------------

# Move (and optionally focus) the window, centred on the given display rect.
move_window() {
  local dx="$1" dy="$2" dw="$3" dh="$4" focus="$5" out rc
  set +e
  out="$(osascript - "$APP_BUNDLE_ID" "$dx" "$dy" "$dw" "$dh" "$focus" <<'APPLESCRIPT' 2>&1
on run argv
  set bundleID to item 1 of argv
  set dx to (item 2 of argv) as integer
  set dy to (item 3 of argv) as integer
  set dw to (item 4 of argv) as integer
  set dh to (item 5 of argv) as integer
  set focusIt to (item 6 of argv) is "focus"
  tell application "System Events"
    if not (exists (first process whose bundle identifier is bundleID)) then error "Mabinogi Mobile is not running (bundle " & bundleID & " not found)."
    set p to first process whose bundle identifier is bundleID
    set w to first window of p
    set {ww, wh} to size of w
    set nx to dx + ((dw - ww) div 2)
    set ny to dy + ((dh - wh) div 2)
    if ny < dy then set ny to dy
    set position of w to {nx, ny}
    if focusIt then set frontmost of p to true
    return "moved to " & nx & "," & ny & " (window " & ww & "x" & wh & ")"
  end tell
end run
APPLESCRIPT
)"
  rc=$?
  set -e
  [[ $rc -ne 0 ]] && fail_osascript "$out"
  echo "$out"
}

# Raise the app without moving its window (idempotent: frontmost=true twice is
# the same as once).
focus_window() {
  local out rc
  set +e
  out="$(osascript - "$APP_BUNDLE_ID" <<'APPLESCRIPT' 2>&1
on run argv
  set bundleID to item 1 of argv
  tell application "System Events"
    if not (exists (first process whose bundle identifier is bundleID)) then error "Mabinogi Mobile is not running (bundle " & bundleID & " not found)."
    set frontmost of (first process whose bundle identifier is bundleID) to true
  end tell
end run
APPLESCRIPT
)"
  rc=$?
  set -e
  # `if`, not `[[ ]] && …`: as the function's last statement a false test would
  # leak exit 1, and under `set -e` that aborts the caller before its no-op echo.
  if [[ $rc -ne 0 ]]; then fail_osascript "$out"; fi
}

# Move the window to a named location: "foreground" (main, focused) or
# "background" (virtual, unfocused). Idempotent: if the window is already on the
# target monitor, do not move it — only re-assert focus for foreground.
move_to() {
  local target="$1" x y w h
  load_window_frame
  if [[ "$(window_location)" == "$target" ]]; then
    if [[ "$target" == "foreground" ]]; then
      focus_window
      echo "already on main monitor (foreground) at (${FRAME_PX},${FRAME_PY}); focused, no move"
    else
      echo "already on virtual monitor (background) at (${FRAME_PX},${FRAME_PY}); no move"
    fi
    return
  fi
  if [[ "$target" == "foreground" ]]; then
    read -r x y w h <<<"$(pick_display main)"
    move_window "$x" "$y" "$w" "$h" focus
  else
    read -r x y w h <<<"$(pick_display virtual)"
    [[ -z "${x:-}" ]] && die "no virtual/secondary monitor found. Is the BetterDisplay virtual screen enabled?"
    move_window "$x" "$y" "$w" "$h" nofocus
  fi
}

# Report whether the app is on (running) or off, and if on, which monitor its
# window sits on. A stopped app is "off" — a real state, not an error (exit 0).
do_status() {
  if [[ -z "$(app_pid)" ]]; then
    echo "Mabinogi is off (not running)"
    return
  fi
  load_window_frame
  local loc label
  loc="$(window_location)"
  case "$loc" in
    foreground) label="main monitor (foreground)" ;;
    background) label="virtual monitor (background)" ;;
    *)          label="off-screen / unknown" ;;
  esac
  echo "Mabinogi is on at (${FRAME_PX},${FRAME_PY}) size ${FRAME_W}x${FRAME_H} -> ${label}"
}

# Turn the app on: if it is not running, launch it and move it onto the main
# monitor (focused). If it is already running, leave the window untouched — on is
# only a power switch, not a "bring to front". Idempotent either way.
do_on() {
  local pid
  pid="$(app_pid)"
  if [[ -n "$pid" ]]; then
    echo "Mabinogi is already on (running, pid ${pid}); no move"
    return
  fi
  open -b "$APP_BUNDLE_ID" || die "could not launch ${APP_LABEL} (bundle ${APP_BUNDLE_ID})."
  wait_for_window || die "${APP_LABEL} launched but no window appeared within 30s."
  move_to foreground
}

# Turn the app off: quit it with a graceful SIGTERM. Idempotent: a no-op when the
# app is already stopped. SIGTERM (kill's default) lets the app terminate itself,
# which needs no Automation permission — unlike an Apple Events "quit".
do_off() {
  local pid
  pid="$(app_pid)"
  if [[ -z "$pid" ]]; then
    echo "Mabinogi is already off (not running); no-op"
    return
  fi
  kill "$pid" 2>/dev/null || die "could not quit ${APP_LABEL} (pid ${pid})."
  echo "quit ${APP_LABEL} (pid ${pid})"
}

# CGWindowID of the app's main window (largest layer-0 window it owns). Matched by
# PID, because the window-server owner name is the localized app title
# (마비노기 모바일) — not something we can match on. The PID comes from the bundle id
# via lsappinfo, keeping the same stable key used everywhere else. Empty on miss.
window_id() {
  local pid
  pid="$(app_pid)"
  [[ -z "$pid" ]] && return 1
  swift - "$pid" <<'SWIFT'
import CoreGraphics
import Foundation
let pid = Int(CommandLine.arguments[1]) ?? -1
guard let list = CGWindowListCopyWindowInfo([], kCGNullWindowID) as? [[String: Any]] else { exit(1) }
var bestID = 0, bestArea = -1.0
for w in list {
  guard (w[kCGWindowOwnerPID as String] as? Int) == pid,
        (w[kCGWindowLayer as String] as? Int) == 0,
        let id = w[kCGWindowNumber as String] as? Int,
        let b = w[kCGWindowBounds as String] as? [String: Double] else { continue }
  let area = (b["Width"] ?? 0) * (b["Height"] ?? 0)   // largest owned window = the game, not the 1920x30 strips
  if area > bestArea { bestArea = area; bestID = id }
}
if bestID != 0 { print(bestID) } else { exit(2) }
SWIFT
}

# Capture only the Mabinogi window (by window id, no desktop, no shadow) and open
# it in Preview. Read-only: never moves or focuses the window, and works whichever
# monitor it is on — including the off-screen virtual one.
do_screenshot() {
  load_window_frame                                  # for the location label + a clear error if not running
  local loc wid
  loc="$(window_location)"
  wid="$(window_id)" || die "could not find the Mabinogi window."
  [[ -z "$wid" ]] && die "could not find the Mabinogi window."
  local shot_dir out
  shot_dir="${TMPDIR:-/tmp}/mobinogi-window"
  mkdir -p "$shot_dir"
  out="${shot_dir}/mabinogi.png"                     # fixed path: overwritten each run, never accumulates
  screencapture -x -o -l "$wid" "$out" || die "screencapture failed."
  open "$out"
  echo "captured Mabinogi window (id ${wid}, currently ${loc}) -> ${out} (opened in Preview)"
}

# --- Dispatch ------------------------------------------------------------------

# Subcommand table — the single source of truth for the accepted names, their
# aliases, and their one-line descriptions. Dispatch (below) and shell completion
# (`__complete`, consumed by completions/_mobinogi-window) both derive from this,
# so the completion can never drift out of sync with what the script accepts.
# Each row: "canonical|space-separated aliases|description".
SUBCOMMANDS=(
  "status|st|report on/off, and if on, which monitor the window is on"
  "screenshot|shot ss|capture just the game window, open in Preview"
  "on||turn the app on (launch to the main monitor if not running)"
  "off||turn the app off (quit)"
  "foreground|fg|move to the main monitor and focus it"
  "background|bg|park it on the virtual monitor (no focus)"
)

# Resolve a user-typed action to its canonical name on stdout (exit 1 if unknown).
resolve_action() {
  local want="$1" row canonical aliases
  for row in "${SUBCOMMANDS[@]}"; do
    IFS='|' read -r canonical aliases _ <<<"$row"
    if [[ "$want" == "$canonical" || " $aliases " == *" $want "* ]]; then
      echo "$canonical"; return 0
    fi
  done
  return 1
}

# Render the full zsh completion file from SUBCOMMANDS (the single source of
# truth), emitting one candidate per accepted name — canonical and each alias.
# The committed completions/_mobinogi-window is exactly this output; a pre-commit
# hook regenerates and diffs to block drift. Hidden command, not shown in usage.
render_completion() {
  local row canonical aliases desc a
  cat <<'HEADER'
#compdef mobinogi-window scripts/mobinogi-window

# GENERATED from scripts/mobinogi-window — do not edit by hand.
# Regenerate: scripts/mobinogi-window __complete > completions/_mobinogi-window
# The pre-commit hook (mabinogi-completion-sync) fails the commit on any drift.
_mobinogi-window() {
  (( CURRENT == 2 )) || return 0   # only the first argument takes a subcommand

  local -a subcommands
  subcommands=(
HEADER
  for row in "${SUBCOMMANDS[@]}"; do
    IFS='|' read -r canonical aliases desc <<<"$row"
    echo "    '$canonical:$desc'"
    for a in $aliases; do echo "    '$a:alias for $canonical'"; done
  done
  cat <<'FOOTER'
  )
  _describe -t subcommands 'subcommand' subcommands
}

_mobinogi-window "$@"
FOOTER
}

[[ "$action" == "__complete" ]] && { render_completion; exit 0; }

case "$(resolve_action "$action" || true)" in
  status)     do_status ;;
  screenshot) do_screenshot ;;
  on)         do_on ;;
  off)        do_off ;;
  foreground) move_to foreground ;;
  background) move_to background ;;
  *)          usage ;;
esac
